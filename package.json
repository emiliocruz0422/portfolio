{
  "name": "react-tailwindcss-prettier-eslint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "SET PORT=3003 & react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx,json}",
    "lint:fix": "eslint --fix src/**/*.{js,jsx,ts,tsx,json}",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md,json} --config ./.prettierrc.json",
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json}": "npm run lint",
    "src/**/*.{js,jsx,ts,tsx,css,md,json}": "npm run format"
  },
  "dependencies": {
    "@apollo/client": "^3.10.8",
    "@headlessui/react": "^2.0.3",
    "@reduxjs/toolkit": "^2.2.3",
    "@tanstack/react-query": "^5.35.1",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.7.13",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "@wagmi/core": "^2.10.5",
    "@web3modal/siwe": "^4.1.11",
    "@web3modal/wagmi": "^4.1.11",
    "alchemy-sdk": "^3.3.1",
    "apexcharts": "^3.51.0",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "ethers": "^6.13.4",
    "graphql": "^16.9.0",
    "notistack": "^3.0.1",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^9.6.0",
    "postcss-url": "^10.1.3",
    "react": "^18.2.0",
    "react-apexcharts": "^1.4.1",
    "react-device-detect": "^2.2.3",
    "react-dom": "^18.2.0",
    "react-lazy-load-image-component": "^1.6.2",
    "react-multi-carousel": "^2.8.5",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "^5.0.1",
    "recharts": "^2.12.5",
    "siwe": "^2.3.2",
    "swr": "^2.2.5",
    "typescript": "^5.4.5",
    "viem": "^2.10.2",
    "wagmi": "^2.8.3",
    "web-vitals": "^2.1.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.39",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3"
  }
}
